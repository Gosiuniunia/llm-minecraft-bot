# ─── Minecraft Server ────────────────────────────────────────────
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=LLMBot
MC_VERSION=1.20.1

# ─── LLM Provider: "ollama" | "anthropic" | "openai" ────────────
LLM_PROVIDER=ollama

# ─── Ollama (local) ──────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Anthropic ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ─── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

# ─── Bot Behaviour ───────────────────────────────────────────────
# Prefix players must type to trigger the bot
TRIGGER_PREFIX=llm-bot
# Max LLM tool-call steps before giving up
MAX_STEPS=20
# Cooldown in ms between accepting new commands per player
COMMAND_COOLDOWN_MS=5000
